# --- Next.js does not load this file. ---
# Copy to `.env.local` for local development (then restart `npm run dev`):
#   cp .env.example .env.local
# Put real secrets only in `.env.local` (gitignored). This file should stay placeholder-only.

# Public site URL for metadata, Open Graph, and absolute links in production.
# Leave unset in local dev, or use a full absolute URL (e.g. https://your-domain.com).
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Supabase — Project Settings → API (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key: server-only. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your-key-secret

# Webhook signing secret (Razorpay Dashboard → Webhooks). Required on Vercel.
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Local `npm run dev` only: skip Razorpay checkout and mark submission paid (tests report flow).
# Set both to 1 in .env.local. Server refuses unless NODE_ENV=development (never on Vercel prod).
# RAZORPAY_DEV_SKIP_PAYMENT=1
# NEXT_PUBLIC_RAZORPAY_DEV_SKIP_PAYMENT=1

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key
# Optional model override for resume analysis.
OPENAI_ANALYSIS_MODEL=gpt-4.1-mini

# Resend (https://resend.com/api-keys) — verified domain / sender
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Resume Analyzer <reports@your-domain.com>
# Comma-separated internal notification addresses.
RESUME_ANALYZER_ADMIN_EMAILS=admin@your-domain.com

# Placeholder admin auth: `/admin?adminKey=...` or header `x-admin-key`.
# If the value contains `$`, you MUST use single quotes in `.env.local` or Next.js will
# strip everything from `$` onward (variable expansion), e.g. ADMIN_DASHBOARD_KEY='my$secret'
ADMIN_DASHBOARD_KEY=
